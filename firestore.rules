rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Service account (Cloud Run ingest) writes have no auth uid.
    function isService() {
      return request.auth == null || request.auth.uid == null;
    }
    // Verified team member (console users). Allowed email domains below.
    // NB: Firestore rules have no string.endsWith(); use matches() with a
    // RE2 regex anchored to the domain.
    function isTeam() {
      return request.auth != null &&
             request.auth.token.email_verified == true &&
             (request.auth.token.email.matches('.*@grantmaster[.]nl$') ||
              request.auth.token.email.matches('.*@gible[.]com$'));
    }

    match /organizations/{document=**} {
      allow write: if isService();
      allow read: if isTeam();
    }

    match /signals/{document=**} {
      allow write: if isService();
      allow read: if isTeam();
    }

    match /accountScores/{document=**} {
      allow write: if isService();
      allow read: if isTeam();
    }

    match /sources/{document=**} {
      allow read: if isTeam();
      // Console can toggle/edit source config; ingest also writes via service.
      allow write: if isService() || isTeam();
    }

    match /syncLogs/{document=**} {
      allow write: if isService() || isTeam(); // team can enqueue a manual run
      allow read: if isTeam();
    }

    // Console-owned: human review decisions.
    match /reviewQueue/{document=**} {
      allow read, write: if isTeam();
    }

    // Console-owned: console configuration (doc id: "console").
    match /settings/{document=**} {
      allow read, write: if isTeam();
    }

    match /rawSnapshots/{document=**} {
      allow write: if isService();
      allow read: if false; // Immutable, accessed via GCS
    }
  }
}
