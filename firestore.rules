rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow service account writes (Cloud Run jobs)
    // Only allow authorized team read access to organizations

    match /organizations/{document=**} {
      // Service: Write (ingest)
      allow write: if request.auth.uid == null &&
                      request.headers['authorization'] != null;
      // Team: Read (view prospects)
      allow read: if request.auth.token.email_verified &&
                     request.auth.token.email.endsWith('@grantmaster.nl');
    }

    match /signals/{document=**} {
      allow write: if request.auth.uid == null;
      allow read: if request.auth.token.email_verified &&
                     request.auth.token.email.endsWith('@grantmaster.nl');
    }

    match /accountScores/{document=**} {
      allow write: if request.auth.uid == null;
      allow read: if request.auth.token.email_verified &&
                     request.auth.token.email.endsWith('@grantmaster.nl');
    }

    match /sources/{document=**} {
      allow read: if request.auth.token.email_verified;
      allow write: if false; // Admin only, set via GCP console
    }

    match /syncLogs/{document=**} {
      allow write: if request.auth.uid == null;
      allow read: if request.auth.token.email_verified;
    }

    match /reviewQueue/{document=**} {
      allow read, write: if request.auth.token.email_verified &&
                            request.auth.token.email.endsWith('@grantmaster.nl');
    }

    match /rawSnapshots/{document=**} {
      allow write: if request.auth.uid == null;
      allow read: if false; // Immutable, accessed via GCS
    }
  }
}
