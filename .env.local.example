# Local development environment
# Copy to .env.local and fill in values as needed

GCP_PROJECT_ID=grantscout-dev
FIRESTORE_DATABASE_ID=(default)
GCS_RAW_BUCKET=grantscout-raw-dev
GEMINI_API_KEY=
