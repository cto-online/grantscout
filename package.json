{
  "name": "grantscout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "workspaces": [
    ".",
    "console"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm -w console run build",
    "typecheck": "tsc --noEmit && npm -w console run build",
    "test": "vitest run && npm -w console run test",
    "test:watch": "vitest",
    "lint": "eslint src test --ext .ts && npm -w console run lint",
    "pipeline:once": "tsx src/index.ts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:console": "npm -w console run dev",
    "docker:build": "docker build -t grantscout:latest .",
    "docker:test": "docker run --rm grantscout:latest --source anbi-nl"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "firebase-admin": "^13.0.0",
    "genkit": "^1.0.0",
    "@genkit-ai/googleai": "^1.0.0",
    "typesense": "^1.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
